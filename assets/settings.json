{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ],
    "allow": [
      "Bash(git *)",
      "Bash(cmake *)",
      "Bash(make *)",
      "Bash(*openocd*)",
      "Bash(STM32_Programmer_CLI *)",
      "Bash(arm-none-eabi-*)",
      "Bash(JLink.exe *)",
      "Bash(where *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ]
  }
}
